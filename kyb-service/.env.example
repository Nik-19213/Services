# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/innovixus_kyb

# ── HTTP server ───────────────────────────────────────────────────────────────
PORT=4100

# ── Didit (https://didit.me) ──────────────────────────────────────────────────
# Application (secret) API key, sent as the x-api-key header on every request.
# Use a sandbox Application's key here for local dev, a production Application's
# key in production -- Didit distinguishes environment by which key you use,
# not by a different host.
DIDIT_API_KEY=
# The workflow ID for your configured KYB (Business Verification) workflow,
# set up in the Didit dashboard -- NOT a KYC/individual workflow ID.
DIDIT_KYB_WORKFLOW_ID=
# secret_shared_key returned once when you create the webhook destination in
# the Didit dashboard -- used to verify the X-Signature-V2 HMAC on inbound
# webhooks. Store it immediately; Didit will not show it again.
DIDIT_WEBHOOK_SECRET=
# Where Didit redirects the business after they finish the hosted KYB flow
# (a page in your own frontend, not this service).
DIDIT_CALLBACK_URL=http://localhost:5173/kyb/complete

# ── Besu network / on-chain verification ─────────────────────────────────────
BESU_RPC_URL=http://localhost:8545
# Private key of an address holding VERIFIER_ROLE on OrganizationRegistry.
# This service uses it to call verifyOrganization once Didit reports Approved.
VERIFIER_PRIVATE_KEY=
ORGANIZATION_REGISTRY_ADDRESS=
