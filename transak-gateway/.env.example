# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
APP_BASE_URL=http://localhost:4000

# Shared secret used to verify JWTs issued by YOUR main application/auth
# system. This service does not do its own login — it trusts a bearer JWT
# from your existing user auth and just needs the user id out of it.
JWT_SECRET=replace_with_a_long_random_string

# ---------------------------------------------------------------------------
# Transak — get these from https://dashboard.transak.com (staging first!)
# ---------------------------------------------------------------------------
# STAGING while testing, PRODUCTION when you go live
TRANSAK_ENVIRONMENT=STAGING

TRANSAK_API_KEY=your_transak_api_key
TRANSAK_API_SECRET=your_transak_api_secret

# Base URLs (rarely change, kept configurable on purpose)
TRANSAK_API_BASE_URL_STAGING=https://api-stg.transak.com
TRANSAK_API_BASE_URL_PRODUCTION=https://api.transak.com
TRANSAK_WIDGET_URL_STAGING=https://global-stg.transak.com
TRANSAK_WIDGET_URL_PRODUCTION=https://global.transak.com

# Transak now requires the widget URL to be minted via a server-to-server
# API call (a different host from TRANSAK_API_BASE_URL above) rather than
# built by hand — see docs.transak.com/api/public/create-widget-url.
# Production host isn't explicitly confirmed in Transak's docs as of when
# this was written — verify in your dashboard/with support before going live.
TRANSAK_WIDGET_API_BASE_URL_STAGING=https://api-gateway-stg.transak.com
TRANSAK_WIDGET_API_BASE_URL_PRODUCTION=https://api-gateway.transak.com

# Must exactly match a domain you've whitelisted for this API key in the
# Transak dashboard (Settings -> API key -> Secure Widget URL / allowed
# domains). Requests with a non-whitelisted referrerDomain will be rejected.
TRANSAK_REFERRER_DOMAIN=localhost

# Secret used to verify the signature Transak sends on webhook calls.
# Confirm the exact header name + secret in your Transak dashboard's
# webhook settings — see the header name below.
TRANSAK_WEBHOOK_SECRET=your_transak_webhook_secret
TRANSAK_WEBHOOK_SIGNATURE_HEADER=x-transak-webhook-signature

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transak_gateway
