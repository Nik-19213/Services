# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate keys by running: node generate-vapid-keys.js
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=you@example.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: use an App Password (myaccount.google.com/apppasswords), not your real password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Messenger dApp <you@gmail.com>

# ── Security ──────────────────────────────────────────────────────────────────
# Optional: any caller must send this in the X-Api-Key header
API_KEY=
