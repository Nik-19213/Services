NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Postgres connection string, e.g. postgres://user:password@host:5432/dbname
# Managed providers (Neon, Supabase, RDS) usually require SSL — set DATABASE_SSL=true then.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kyc_otp
DATABASE_SSL=false
DB_POOL_MAX=10

# Comma-separated list of browser origins allowed to call this API, e.g.
# https://app.example.com,https://admin.example.com
# Leave empty in development to allow all origins.
CORS_ORIGINS=

# Set to true only when running behind a reverse proxy/load balancer (nginx, Render,
# Fly, Heroku, ALB) so req.ip and rate limiting read the real client IP.
TRUST_PROXY=false

# Twilio Verify (OTP) — from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Didit identity verification (KYC) — from https://business.didit.me
DIDIT_BASE_URL=https://verification.didit.me
DIDIT_API_KEY=your_didit_api_key
DIDIT_WORKFLOW_ID=your_didit_workflow_id
# Secret shown once when you create the webhook destination in the Didit console
DIDIT_WEBHOOK_SECRET_KEY=your_didit_webhook_secret
# Where Didit redirects the user's browser after they finish the hosted verification flow
DIDIT_CALLBACK_URL=https://your-app.example.com/kyc/complete
